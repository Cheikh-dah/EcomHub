# Copy to .env and fill in real values. The server loads .env from the working directory (run from this folder).
# Clerk + session bridge: docs/AUTH-BRIDGE.md

# --- Postgres (matches docker-compose.yml service `postgres`) ---
# Use host `localhost` when the Go app runs on your machine (typical: `go run ./cmd/server`).
DATABASE_URL=postgres://ecomhub:ecomhub@localhost:5432/ecomhub?sslmode=disable

PORT=8080
# Allowed: development | staging | production
ENVIRONMENT=development
# Recommended: public base URL of this app (used for Clerk session `azp` allow-list when CLERK_AUTHORIZED_PARTIES is unset)
APP_URL=http://localhost:8080

# --- Clerk (required for auth + dashboard) ---
# Dashboard → API keys → Secret key (sk_test_... / sk_live_...)
CLERK_SECRET_KEY=sk_test_your_secret_key
# Publishable key (pk_test_... / pk_live_...) — safe in the browser; used by Clerk JS on /dashboard
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
# Optional: full Frontend API URL from the same page, e.g. https://your-instance.clerk.accounts.dev
# If unset, the dashboard derives it from the publishable key (Clerk’s documented base64 segment).
# CLERK_FRONTEND_API=https://your-instance.clerk.accounts.dev
# Optional: comma-separated origins allowed in the JWT `azp` claim (tighten in production). If unset, APP_URL is used when set.
# CLERK_AUTHORIZED_PARTIES=http://localhost:8080,https://your-production-host

# Optional — multi-tenant host routing (not fully wired in routing yet)
# BASE_HOST=localhost
