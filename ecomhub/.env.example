# Copy to .env and fill in real values. The server loads .env from the working directory (run from this folder).

# --- Postgres (matches docker-compose.yml service `postgres`) ---
# Use host `localhost` when the Go app runs on your machine (typical: `go run ./cmd/server`).
# Use host `postgres` when the Go app runs in Docker on the same Compose network.
DATABASE_URL=postgres://ecomhub:ecomhub@localhost:5432/ecomhub?sslmode=disable

# --- App (interim JWT until Supabase-backed auth replaces app-signed tokens) ---
# Generate a strong secret, e.g. `openssl rand -base64 32` (Git Bash/WSL) — do not commit real .env
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_AT_LEAST_16_CHARS
JWT_EXPIRY_HOURS=72
PORT=8080
# Allowed: development | staging | production (staging/production require https SUPABASE_URL)
ENVIRONMENT=development
# Optional until redirects / email / OAuth callbacks need it (must be https in production when set)
APP_URL=http://localhost:8080

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
# MUST be the "JWT Secret" from Supabase Dashboard → Settings → API (JWT signing secret).
# NOT the anon key. NOT the service_role key.
SUPABASE_JWT_SECRET=your_real_jwt_secret_from_dashboard

# Optional — if set, must be complete keys (no partial values); see config validation min lengths
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY=

# --- Multi-tenant (optional) ---
# BASE_HOST=localhost
